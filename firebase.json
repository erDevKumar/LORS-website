{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/apply",
        "destination": "https://docs.google.com/forms/d/e/1FAIpQLSceU0YNp_Rjee9O_hYt3TnK-sE4W6ApG4zo7Qub6U8_mmOuXQ/viewform",
        "type": 302
      }
    ]
  }
}
